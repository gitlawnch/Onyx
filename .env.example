# ============================================================================
# Base Alpha — Environment Configuration
# ============================================================================
# Copy this file to `.env.local` and fill in the values you have.
# The app degrades gracefully: any source without credentials is reported as
# "unknown" in the UI rather than faked. Nothing here is required to boot.
# ============================================================================

# ---- Base chain RPC (KEYLESS by default, with automatic fallback) ----------
# The app already rotates through a pool of public Base RPC endpoints and
# switches automatically if one is down or rate-limited — so it works with no
# config. For best reliability in production, set a dedicated (paid) endpoint
# here; it will be tried FIRST, with the public pool as automatic fallback.
NEXT_PUBLIC_BASE_RPC_URL="https://mainnet.base.org"

# ---- BaseScan (KEY REQUIRED for tx counts, holders, contract age) ----------
# Free tier: https://basescan.org/myapikey
# Without this, wallet tx counts / token holder counts / contract age = "unknown".
# TIP: you can provide SEVERAL keys separated by commas — the app rotates
# through them round-robin to avoid hitting a single key's rate limit, e.g.:
#   BASESCAN_API_KEY="key1,key2,key3"
BASESCAN_API_KEY=""
BASESCAN_API_URL="https://api.basescan.org/api"

# ---- DexScreener (KEYLESS) -------------------------------------------------
# No key needed. Used for token price, liquidity, volume, market cap.
DEXSCREENER_API_URL="https://api.dexscreener.com"

# ---- DefiLlama (KEYLESS) ---------------------------------------------------
# No key needed. Used for protocol TVL + the Base protocol list.
DEFILLAMA_API_URL="https://api.llama.fi"

# ---- CoinGecko (KEYLESS public, or key for higher limits) ------------------
# Public endpoints work without a key. Demo/Pro keys raise rate limits.
COINGECKO_API_URL="https://api.coingecko.com/api/v3"
COINGECKO_API_KEY=""

# ---- Supabase (REQUIRED for: airdrops/quests, smart-money labels, caching) -
# The campaign + smart-money tables live here. Run the migration in
# supabase/migrations to create the schema. See README for details.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key is only used server-side for write/refresh jobs. Never expose.
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Campaign sources (NO PUBLIC API — populated via Supabase) -------------
# Galxe, Layer3, Zealy, and Intract do not offer usable public read APIs for
# tracking arbitrary campaigns. Base Alpha reads campaign records from Supabase
# (the campaigns table), which you populate via your own ingestion jobs or the
# Supabase dashboard. Status is always re-derived from real start/end dates, so
# an ended campaign is never shown as ongoing. See:
#   src/lib/adapters/campaigns.ts       (adapter + status logic)
#   supabase/migrations/0001_init.sql   (campaigns table)

# ---- Smart-money wallet labels (PROPRIETARY — populated via Supabase) -------
# "Smart money" labeling is a proprietary dataset (Nansen-style). There is no
# free API. Base Alpha reads labeled wallets from the `tracked_wallets` table
# in Supabase, which you populate from your own labeling pipeline.
